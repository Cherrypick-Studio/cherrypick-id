		opacity: 0.65;
	}
	.wave-paths path:nth-child(5) {
		animation: wave-move 4s ease-in-out infinite;
		animation-delay: 0.6s;
		opacity: 0.6;
	}
	.wave-paths path:nth-child(6) {
