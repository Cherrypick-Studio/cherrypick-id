<style>
	.wave-paths path {
		stroke: #c42026;
		stroke-width: 0.5;
		fill: none;
		opacity: 0.6;
	}

	:global(.dark) .wave-paths path {
		stroke: #ffffff;
	}

	.wave-animation {
		animation: wave-float 12s ease-in-out infinite;
	}

	.wave-paths path:nth-child(1) {
