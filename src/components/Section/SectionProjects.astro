---
import heroImg from '../../assets/ic-clients.svg';
import CountUp from '../CountUp.astro';
import { whatsappUrlWithText } from '../../config';

const projects = [
	'UMKM & Bisnis Lokal',
	'Restoran',
	'Cafe & Coffee Shop',
	'Properti',
	'Travel & Tour',
	'Lembaga Pendidikan',
	'Klinik Kesehatan',
	'Klinik Kecantikan',
	'Agen Perumahan',
	'Agen Kos',
	'Agen Apartemen',
	'Logistik',
	'Cargo & Jasa Ekspedisi',
	'Manufaktur',
	'Supplier B2B',
	'IT Services',
	'Internet Provider (ISP)',
	'Telekomunikasi',
	'Energy & Green Technology',
	'Barbershop',
	'Fitness & Personal Trainer',
	'Wedding Organizer',
	'Pet Care',
	'Penyewaan Mobil',
	'Hotel & Penginapan',
	'Wedding Organizer',
	'Komunitas',
	'Gym',
	'NGO & Program Sosial',
	'Sekolah',
	'Kursus Online',
	'Kontraktor',
	'Dental Clinic',
	'Dokter Spesialis',
	'Developer Perumahan',
	'Event Organizer',
	'Recruitment Agency',
	'Konsultan Bisnis',
	'Konsultan Pajak',
	'Konsultan Keuangan',
	'Startup Teknologi',
	'Jasa Percetakan',
	'Pet Shop',
	'Vendor Pernikahan',
];

const satisfiedClients = [
	{ name: 'Budi Santoso', avatar: 'BS' },
	{ name: 'Siti Rahayu', avatar: 'SR' },
	{ name: 'Ahmad Wijaya', avatar: 'AW' },
];

const avatarColors = ['bg-[#7C3AED]', 'bg-[#C42026]', 'bg-[#059669]'];
---

<div
	class='w-full relative h-fit overflow-hidden bg-[#EFEFEF] dark:bg-[#0A0A0A]'
>
	<div
		class='max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-[110px] flex flex-col gap-[64px]'
	>
		<div class='flex flex-col lg:flex-row justify-between items-center'>
			<div class='flex flex-col gap-6'>
				<h2
					class='text-[40px] font-semibold text-[#1A1A1A] dark:text-[#FEFEFE] lg:max-w-[500px]'
				>
					Klien yang Pernah Bekerja Sama dengan Kami
				</h2>
				<p class='text-lg text-[#666666] dark:text-[#BBBBBB]'>
					Dari UMKM hingga perusahaan, kami membantu klien memiliki website yang
					profesional dan siap digunakan. <br />
					Mau jadi klien berikutnya?
				</p>
				<div
					class='flex flex-col lg:flex-row gap-6 items-start lg:items-center mt-6 lg:mb-0 mb-6'
				>
					<a
						href={whatsappUrlWithText('Halo, saya tertarik dengan paket')}
						target='_blank'
						rel='noopener noreferrer'
						class='bg-[#1A1A1A] dark:bg-white text-white dark:text-[#1A1A1A] hover:opacity-80 flex items-center py-4 px-6 gap-3 rounded-xl'
					>
						<svg
							class='w-5 h-5'
							fill='currentColor'
							viewBox='0 0 24 24'
							aria-hidden='true'
						>
							<path
								d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'
							></path>
						</svg>
						Konsultasi Gratis
					</a>
					<div class='flex gap-4'>
						<div class='flex flex-col gap-0'>
							<CountUp
								target={98}
								suffix='%'
								class='text-2xl text-[#1A1A1A] font-semibold dark:text-[#FEFEFE]'
							/>
							<span class='text-sm text-[#666666] dark:text-[#BBBBBB]'
								>Klien Puas</span
							>
						</div>
						<div class='flex -space-x-2'>
							{
								satisfiedClients.map((client, index) => (
									<div
										class={`w-10 h-10 rounded-full border-2 border-white dark:border-[#1A1A1A] ${avatarColors[index]} flex items-center justify-center text-white text-sm font-semibold`}
										title={client.name}
										aria-label={client.name}>
										{client.avatar}
									</div>
								))
							}
						</div>
					</div>
				</div>
			</div>
			<img
				src={heroImg.src}
				alt='Client success illustration'
				class='w-full lg:block'
				width='500'
				height='500'
			/>
		</div>
		<div class='flex flex-col gap-5'>
			<span class='text-lg text-black dark:text-[#FEFEFE]'
				>Sektor Bisnis Populer</span
			>
			<div class='flex flex-wrap gap-3'>
				{
					projects.map((list, index) => (
						<div class='px-3 py-[6px] bg-white dark:bg-[#282828] dark:text-[#999999] rounded-[8px]'>
							{list}
						</div>
					))
				}
			</div>
		</div>
	</div>
</div>
