---
import heroImg from '../../assets/ic-logo-banner.svg';
import WaveBackground from '../WaveBackground.astro';
import CountUp from '../CountUp.astro';

const satisfiedClients = [
	{ name: 'Budi Santoso', avatar: 'BS' },
	{ name: 'Siti Rahayu', avatar: 'SR' },
	{ name: 'Ahmad Wijaya', avatar: 'AW' },
];

const avatarColors = ['bg-[#7C3AED]', 'bg-[#C42026]', 'bg-[#059669]'];
---

<div class='w-full relative h-fit overflow-hidden' id='hero'>
	<WaveBackground />
	<div class='max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-[110px]'>
		<div class='flex justify-between items-center'>
			<div class='flex flex-col gap-6'>
				<h1
					class='text-[56px] font-semibold text-[#1A1A1A] dark:text-[#FEFEFE]'
				>
					Jasa Pembuatan Website Profesional <span
						class='text-[#C42026] dark:text-[#FFCA00]'>Mudah</span
					> & <span class='text-[#C42026] dark:text-[#FFCA00]'>Cepat</span>
				</h1>
				<p class='text-lg text-[#666666] dark:text-[#BBBBBB]'>
					Banyak pemilik bisnis mempunyai website, tapi tidak semuanya
					menghasilkan. <b>Puluhan klien</b> kami mengalami <b
						>peningkatan leads</b
					> dan <b> income 200% </b> setelah menggunakan website yang kami bangun
					secara profesional dan terstruktur.
				</p>
				<div class='flex flex-col lg:flex-row gap-12 items-center mt-6'>
					<div class='flex items-center gap-6'>
						<a
							href='#pricing'
							class='bg-[#C42026] shadow-xl py-4 px-6 rounded-[12px] text-sm font-medium text-[#FEFEFE] hover:opacity-90 transition-opacity'
							>Cek Harga Kami
						</a>
						<a
							href='#portfolio'
							class='bg-white shadow-xl py-4 px-6 rounded-[12px] text-sm font-medium text-[#1A1A1A] hover:opacity-90 transition-opacity'
							>Lihat Portfolio
						</a>
					</div>
					<div class='flex gap-4'>
						<div class='flex flex-col gap-0'>
							<CountUp
								target={98}
								suffix='%'
								class='text-2xl text-[#1A1A1A] font-semibold dark:text-[#FEFEFE]'
							/>
							<span class='text-sm text-[#666666] dark:text-[#BBBBBB]'
								>Klien Puas</span
							>
						</div>
						<div class='flex -space-x-2'>
							{
								satisfiedClients.map((client, index) => (
									<div
										class={`w-10 h-10 rounded-full border-2 border-white dark:border-[#1A1A1A] ${avatarColors[index]} flex items-center justify-center text-white text-sm font-semibold`}
										title={client.name}
										aria-label={client.name}
									>
										{client.avatar}
									</div>
								))
							}
						</div>
					</div>
				</div>
			</div>
			<img
				src={heroImg.src}
				alt='Cherrypick website design illustration'
				class='w-full hidden lg:block animate-float'
				width='600'
				height='600'
			/>
		</div>
	</div>
</div>

<style>
	@keyframes float {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-12px);
		}
	}
	.animate-float {
		animation: float 3s ease-in-out infinite;
	}
	
	@media (prefers-reduced-motion: reduce) {
		.animate-float {
			animation: none;
		}
	}
</style>
