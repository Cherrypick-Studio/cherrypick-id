---
import logo from '../assets/ic-logo-wording.svg';
import logoWhite from '../assets/ic-logo-wording-white.svg';
---

<footer
	class='bg-[#FFF5F6] dark:bg-[#282828] text-white py-12 transition-colors border-t border-[#EBEBEB]'
>
	<div class='max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8'>
		<div class='flex flex-col justify-between gap-8'>
			<div class='flex flex-col space-y-6'>
				<div class='flex w-full justify-between'>
					<h2 class='text-xl font-bold text-[#1A1A1A] dark:text-white'>
						Jasa Pembuatan Website Profesional Mudah & Cepat
					</h2>
					<img
						src={logo.src}
						alt='Cherrypick'
						class='h-12 w-auto dark:hidden'
					/>
					<img
						src={logoWhite.src}
						alt='Cherrypick'
						class='h-12 w-auto hidden dark:block'
					/>
				</div>

				<div
					class='flex flex-col sm:flex-row gap-6 text-gray-400 dark:text-gray-300'
				>
					<div class='flex items-start gap-2'>
						<svg
							class='w-5 h-5 mt-0.5 flex-shrink-0'
							fill='none'
							stroke='currentColor'
							viewBox='0 0 24 24'
						>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								stroke-width='2'
								d='M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z'
							></path>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								stroke-width='2'
								d='M15 11a3 3 0 11-6 0 3 3 0 016 0z'></path>
						</svg>
						<span>Jl. Contoh Alamat No. 123, Jakarta, Indonesia</span>
					</div>
					<div class='flex items-center gap-2'>
						<svg
							class='w-5 h-5 flex-shrink-0'
							fill='none'
							stroke='currentColor'
							viewBox='0 0 24 24'
						>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								stroke-width='2'
								d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'
							></path>
						</svg>
						<span>+62 812-3456-7890</span>
					</div>
					<div class='flex items-center gap-2'>
						<svg
							class='w-5 h-5 flex-shrink-0'
							fill='none'
							stroke='currentColor'
							viewBox='0 0 24 24'
						>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								stroke-width='2'
								d='M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'
							></path>
						</svg>
						<span>hello@cherrypick.id</span>
					</div>
				</div>
			</div>

			<div class='flex flex-row items-start w-full justify-between gap-4'>
				<p class='text-gray-400 dark:text-gray-300 text-sm'>
					© 2025 Cherrypick. All rights reserved.
				</p>
				<div class='flex gap-4'>
					<a
						href='#'
						class='text-gray-400 dark:text-gray-300 hover:text-red-500 dark:hover:text-red-400 transition-colors'
						aria-label='Facebook'
					>
						<svg class='w-6 h-6' fill='currentColor' viewBox='0 0 24 24'>
							<path
								d='M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z'
							></path>
						</svg>
					</a>
					<a
						href='#'
						class='text-gray-400 dark:text-gray-300 hover:text-red-500 dark:hover:text-red-400 transition-colors'
						aria-label='Instagram'
					>
						<svg class='w-6 h-6' fill='currentColor' viewBox='0 0 24 24'>
							<path
								d='M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z'
							></path>
						</svg>
					</a>
					<a
						href='#'
						class='text-gray-400 dark:text-gray-300 hover:text-red-500 dark:hover:text-red-400 transition-colors'
						aria-label='X (Twitter)'
					>
						<svg class='w-6 h-6' fill='currentColor' viewBox='0 0 24 24'>
							<path
								d='M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z'
							></path>
						</svg>
					</a>
					<a
						href='#'
						class='text-gray-400 dark:text-gray-300 hover:text-red-500 dark:hover:text-red-400 transition-colors'
						aria-label='LinkedIn'
					>
						<svg class='w-6 h-6' fill='currentColor' viewBox='0 0 24 24'>
							<path
								d='M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z'
							></path>
						</svg>
					</a>
					<a
						href='#'
						class='text-gray-400 dark:text-gray-300 hover:text-red-500 dark:hover:text-red-400 transition-colors'
						aria-label='Behance'
					>
						<svg class='w-6 h-6' fill='currentColor' viewBox='0 0 24 24'>
							<path
								d='M6.938 4.503c.702 0 1.34.06 1.92.188.577.13 1.07.33 1.485.61.41.28.733.65.96 1.12.225.47.34 1.05.34 1.73 0 .74-.17 1.36-.507 1.86-.338.5-.837.9-1.502 1.22.906.26 1.576.72 2.022 1.37.448.66.665 1.45.665 2.36 0 .75-.13 1.39-.41 1.93-.28.55-.67 1-1.16 1.35-.48.348-1.05.6-1.67.767-.61.165-1.252.254-1.91.254H0V4.51h6.938v-.007zM6.545 10.2c.552 0 1.009-.137 1.38-.415.37-.275.554-.69.554-1.24 0-.3-.054-.54-.165-.72-.11-.18-.256-.32-.44-.42-.186-.1-.39-.17-.618-.2-.23-.04-.47-.06-.713-.06H3.39v3.06h3.155v-.005zm.156 5.42c.27 0 .52-.03.76-.09.24-.06.45-.16.63-.3.18-.13.32-.31.43-.54.11-.23.16-.52.16-.87 0-.7-.2-1.2-.6-1.49-.4-.3-.92-.44-1.57-.44H3.39v3.73h3.31v.01zm10.21-8.13c-.68 0-1.27.13-1.79.4-.52.27-.96.63-1.31 1.1-.35.46-.61 1-.77 1.63-.16.62-.25 1.3-.25 2.02 0 .73.09 1.39.25 2 .16.61.42 1.14.78 1.58.35.44.79.78 1.32 1.03.53.25 1.14.37 1.84.37.86 0 1.59-.22 2.17-.67.58-.44.99-1.12 1.2-2.02h-2.62c-.07.28-.24.52-.5.71-.26.2-.58.29-.95.29-.57 0-1-.17-1.29-.5-.29-.34-.46-.84-.5-1.52h5.97c.04-.73.01-1.42-.1-2.07-.11-.65-.32-1.21-.64-1.69-.31-.48-.73-.85-1.25-1.12-.52-.27-1.15-.4-1.89-.4v.01zm-1.67 4.16c.06-.57.22-1.04.49-1.42.27-.37.67-.56 1.21-.56.53 0 .93.18 1.21.55.27.37.42.85.45 1.43h-3.36zm-5.69-9.35h6.04v1.64h-6.04V2.28z'
							></path>
						</svg>
					</a>
					<a
						href='#'
						class='text-gray-400 dark:text-gray-300 hover:text-red-500 dark:hover:text-red-400 transition-colors'
						aria-label='Dribbble'
					>
						<svg class='w-6 h-6' fill='currentColor' viewBox='0 0 24 24'>
							<path
								d='M12 24C5.385 24 0 18.615 0 12S5.385 0 12 0s12 5.385 12 12-5.385 12-12 12zm10.12-10.358c-.35-.11-3.17-.953-6.384-.438 1.34 3.684 1.887 6.684 1.992 7.308 2.3-1.555 3.936-4.02 4.395-6.87zm-6.115 7.808c-.153-.9-.75-4.032-2.19-7.77l-.066.02c-5.79 2.015-7.86 6.025-8.04 6.4 1.73 1.358 3.92 2.166 6.29 2.166 1.42 0 2.77-.29 4-.814zm-11.62-2.58c.232-.4 3.045-5.055 8.332-6.765.135-.045.27-.084.405-.12-.26-.585-.54-1.167-.832-1.74C7.17 11.775 2.206 11.71 1.756 11.7l-.004.312c0 2.633.998 5.037 2.634 6.855zm-2.42-8.955c.46.008 4.683.026 9.477-1.248-1.698-3.018-3.53-5.558-3.8-5.928-2.868 1.35-5.01 3.99-5.676 7.17zM9.6 2.052c.282.38 2.145 2.914 3.822 6 3.645-1.365 5.19-3.44 5.373-3.702-1.81-1.61-4.19-2.586-6.795-2.586-.825 0-1.63.1-2.4.285zm10.335 3.483c-.218.29-1.935 2.493-5.724 4.04.24.49.47.985.68 1.486.08.18.15.36.22.53 3.41-.43 6.8.26 7.14.33-.02-2.42-.88-4.64-2.31-6.38z'
							></path>
						</svg>
					</a>
				</div>
			</div>
		</div>
	</div>
</footer>
