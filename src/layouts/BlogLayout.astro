---
import type { CollectionEntry } from 'astro:content';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { whatsappUrlWithText } from '../config';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, image, tags, category } = post.data;

const readingTime = Math.ceil(post.body.split(/\s+/).length / 200);
const formattedPubDate = pubDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });
const isoDate = pubDate.toISOString();
const isoUpdated = updatedDate?.toISOString() ?? isoDate;
const canonicalUrl = `https://id.cherrypick.id/blog/${post.slug}`;
const waUrl = whatsappUrlWithText('Halo Cherrypick, saya mau konsultasi website untuk bisnis saya.');

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	image: image.url,
	author: { '@type': 'Organization', name: author },
	publisher: {
		'@type': 'Organization',
		'@id': 'https://id.cherrypick.id/#organization',
		name: 'Cherrypick Studio',
		logo: { '@type': 'ImageObject', url: 'https://id.cherrypick.id/favicon.svg' },
	},
	datePublished: isoDate,
	dateModified: isoUpdated,
	url: canonicalUrl,
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Beranda', item: 'https://id.cherrypick.id/' },
		{ '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://id.cherrypick.id/blog' },
		{ '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
	],
};
---

<!doctype html>
<html lang='id' class='scroll-smooth'>
	<head>
		<script is:inline>
			const theme = localStorage.getItem('theme') || 'system';
			const isDark =
				theme === 'dark' ||
				(theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
			if (isDark) document.documentElement.classList.add('dark');
		</script>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />

		<title>{title} | Cherrypick Studio</title>
		<meta name='description' content={description} />
		<link rel='canonical' href={canonicalUrl} />
		<link rel='alternate' hreflang='id' href={canonicalUrl} />
		<link rel='alternate' hreflang='x-default' href={canonicalUrl} />

		<meta property='og:type' content='article' />
		<meta property='og:url' content={canonicalUrl} />
		<meta property='og:title' content={`${title} | Cherrypick Studio`} />
		<meta property='og:description' content={description} />
		<meta property='og:image' content={image.url} />
		<meta property='og:locale' content='id_ID' />
		<meta property='og:site_name' content='Cherrypick Studio' />
		<meta property='article:published_time' content={isoDate} />
		<meta property='article:modified_time' content={isoUpdated} />

		<meta name='twitter:card' content='summary_large_image' />
		<meta name='twitter:title' content={`${title} | Cherrypick Studio`} />
		<meta name='twitter:description' content={description} />
		<meta name='twitter:image' content={image.url} />

		<meta name='theme-color' content='#C42026' />
		<meta name='robots' content='index, follow' />
		<meta http-equiv='content-language' content='id' />

		<link rel='preconnect' href='https://www.googletagmanager.com' crossorigin />

		<!-- Google tag (gtag.js) -->
		<script async src='https://www.googletagmanager.com/gtag/js?id=G-ZZSP9JYL3P'></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-ZZSP9JYL3P');
		</script>

		<script type='application/ld+json' is:inline set:html={JSON.stringify(articleSchema)} />
		<script type='application/ld+json' is:inline set:html={JSON.stringify(breadcrumbSchema)} />
	</head>
	<body class='min-h-screen flex flex-col bg-white dark:bg-[#282828] text-gray-900 dark:text-gray-100'>
		<Navbar />
		<main class='flex-1 max-w-[800px] mx-auto w-full px-4 sm:px-6 lg:px-8 pt-32 pb-20'>
			<!-- Breadcrumb -->
			<nav aria-label='Breadcrumb' class='mb-8 text-sm text-gray-500 dark:text-gray-400'>
				<ol class='flex items-center gap-2'>
					<li><a href='/' class='hover:text-[#C42026] transition-colors'>Beranda</a></li>
					<li aria-hidden='true'>/</li>
					<li><a href='/blog' class='hover:text-[#C42026] transition-colors'>Blog</a></li>
					<li aria-hidden='true'>/</li>
					<li class='text-gray-700 dark:text-gray-300 truncate max-w-[200px]'>{title}</li>
				</ol>
			</nav>

			<!-- Post Header -->
			<header class='mb-10'>
				<span class='inline-block bg-[#FFF5F6] dark:bg-[#3a1a1a] text-[#C42026] text-sm font-medium px-3 py-1 rounded-full mb-4'>
					{category}
				</span>
				<h1 class='text-3xl md:text-4xl font-bold text-[#1A1A1A] dark:text-[#FEFEFE] mb-4 leading-tight'>
					{title}
				</h1>
				<div class='flex flex-wrap items-center gap-4 text-sm text-gray-500 dark:text-gray-400'>
					<span>{author}</span>
					<span aria-hidden='true'>·</span>
					<time datetime={isoDate}>{formattedPubDate}</time>
					{updatedDate && (
						<>
							<span aria-hidden='true'>·</span>
							<span>Diperbarui {updatedDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
						</>
					)}
					<span aria-hidden='true'>·</span>
					<span>{readingTime} menit baca</span>
				</div>
				{image && (
					<img
						src={image.url}
						alt={image.alt}
						class='w-full rounded-xl mt-8 object-cover aspect-video'
						width='800'
						height='450'
					/>
				)}
			</header>

			<!-- Post Content -->
			<article class='prose prose-lg dark:prose-invert max-w-none prose-headings:text-[#1A1A1A] dark:prose-headings:text-[#FEFEFE] prose-a:text-[#C42026]'>
				<slot />
			</article>

			<!-- Tags -->
			{tags.length > 0 && (
				<div class='mt-10 flex flex-wrap gap-2'>
					{tags.map((tag) => (
						<span class='bg-gray-100 dark:bg-[#1A1A1A] text-gray-600 dark:text-gray-300 text-sm px-3 py-1 rounded-full'>
							#{tag}
						</span>
					))}
				</div>
			)}

			<!-- Share Buttons -->
			<div class='mt-10 p-6 bg-[#F9F9F9] dark:bg-[#1A1A1A] rounded-xl'>
				<p class='font-semibold text-[#1A1A1A] dark:text-[#FEFEFE] mb-4'>Bagikan artikel ini:</p>
				<div class='flex flex-wrap gap-3'>
					<a
						href={`https://wa.me/?text=${encodeURIComponent(title + ' ' + canonicalUrl)}`}
						target='_blank'
						rel='noopener noreferrer'
						class='flex items-center gap-2 bg-[#25D366] text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90 transition-opacity'
					>
						WhatsApp
					</a>
					<a
						href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(canonicalUrl)}`}
						target='_blank'
						rel='noopener noreferrer'
						class='flex items-center gap-2 bg-[#1DA1F2] text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90 transition-opacity'
					>
						Twitter / X
					</a>
					<a
						href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalUrl)}`}
						target='_blank'
						rel='noopener noreferrer'
						class='flex items-center gap-2 bg-[#0A66C2] text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90 transition-opacity'
					>
						LinkedIn
					</a>
				</div>
			</div>

			<!-- End CTA -->
			<div class='mt-12 p-8 bg-[#C42026] rounded-2xl text-center text-white'>
				<h2 class='text-2xl font-bold mb-3'>Siap Punya Website Profesional?</h2>
				<p class='mb-6 opacity-90'>Konsultasi gratis dengan tim kami. Ceritakan kebutuhan bisnis Anda dan kami siap bantu.</p>
				<a
					href={waUrl}
					target='_blank'
					rel='noopener noreferrer'
					class='inline-block bg-white text-[#C42026] font-bold px-8 py-3 rounded-xl hover:opacity-90 transition-opacity'
				>
					Konsultasi Gratis via WhatsApp
				</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
